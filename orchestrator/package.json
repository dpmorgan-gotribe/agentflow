{
  "name": "orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript runtime driving the two-mode pipeline (Mode A stage-linear design + planning; Mode B feature-graph build) via the Claude Agent SDK. Scaffolding source: scaffolding/21-035-orchestrator-core.md.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "agentflow": "./src/cli.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "tsx src/cli.ts",
    "probe-quota": "node scripts/probe-quota.mjs",
    "dag-status": "node scripts/dag-status.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@repo/orchestrator-contracts": "workspace:*",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
